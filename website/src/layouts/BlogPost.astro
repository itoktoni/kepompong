---
import Layout from "./Layout.astro";
import { siteConfig } from "../config/site";

interface Props {
  title: string;
  description: string;
  author: string;
  pubDate: Date;
  updatedDate?: Date;
  category: string;
  tags: string[];
  image?: { url: string; alt: string };
}

const { title, description, author, pubDate, updatedDate, category, tags, image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<Layout pageKey="/">
  <article class="max-w-6xl mx-auto px-margin-mobile py-20 md:px-margin-desktop">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm">
      <ol class="flex items-center gap-2 text-on-surface-variant">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
        <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
        <li><a href={`/blog/category/${category.toLowerCase()}`} class="hover:text-primary transition-colors">{category}</a></li>
      </ol>
    </nav>

    <!-- Featured Image -->
    {image && (
      <figure class="mb-8 rounded-2xl overflow-hidden">
        <img
          src={image.url}
          alt={image.alt}
          class="w-full h-64 md:h-96 object-cover"
        />
      </figure>
    )}

    <!-- Header -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <a
          href={`/blog/category/${category.toLowerCase()}`}
          class="inline-block px-3 py-1 bg-primary-container text-on-primary-container text-label-lg rounded-full hover:opacity-80 transition-opacity"
        >
          {category}
        </a>
      </div>

      <h1 class="font-fredoka text-3xl md:text-4xl font-bold text-on-surface mb-4 leading-tight">
        {title}
      </h1>

      <p class="text-lg text-on-surface-variant mb-6">
        {description}
      </p>

      <div class="flex flex-wrap items-center gap-4 text-sm text-on-surface-variant">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-base">person</span>
          <span>{author}</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-base">calendar_today</span>
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        </div>
        {updatedDate && (
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-base">update</span>
            <span>Updated: {formattedUpdatedDate}</span>
          </div>
        )}
      </div>
    </header>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-8">
      {tags.map((tag) => (
        <a
          href={`/blog/tag/${tag}`}
          class="px-3 py-1 bg-surface-variant text-on-surface-variant text-label-sm rounded-full hover:bg-primary hover:text-on-primary transition-colors"
        >
          #{tag}
        </a>
      ))}
    </div>

    <!-- Content -->
    <div class="prose prose-lg max-w-none mb-12">
      <slot />
    </div>

    <!-- Share & Navigation -->
    <footer class="border-t border-outline-variant pt-8">
      <div class="flex items-center justify-between mb-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-full hover:opacity-90 transition-opacity font-fredoka"
        >
          <span class="material-symbols-outlined text-base">arrow_back</span>
          Kembali ke Blog
        </a>
      </div>

      <!-- Related by Category -->
      <div class="bg-surface-container rounded-2xl p-6">
        <h3 class="font-fredoka text-xl font-bold text-on-surface mb-4">
          Artikel Lainnya
        </h3>
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-label-lg hover:bg-primary hover:text-on-primary transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </footer>
  </article>
</Layout>

<style is:global>
  .prose {
    color: #1d1b18;
    line-height: 2;
    font-size: 1.125rem;
  }

  .prose h1 {
    font-family: 'Fredoka', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: #1d1b18;
  }

  .prose h2 {
    font-family: 'Fredoka', sans-serif;
    font-size: 2rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #1d1b18;
  }

  .prose h3 {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #1d1b18;
  }

  .prose p {
    margin-bottom: 1.25rem;
    font-size: 1.125rem;
  }

  .prose ul, .prose ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
  }

  .prose ul li {
    list-style-type: disc;
  }

  .prose ol li {
    list-style-type: decimal;
  }

  .prose a {
    color: #176c33;
    text-decoration: underline;
  }

  .prose a:hover {
    color: #004b1e;
  }

  .prose strong {
    font-weight: 600;
    color: #1d1b18;
  }

  .prose blockquote {
    border-left: 4px solid #176c33;
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: #56615a;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }

  .prose th, .prose td {
    border: 1px solid #bfc9bc;
    padding: 0.75rem;
    text-align: left;
  }

  .prose th {
    background-color: #d9e6dc;
    font-weight: 600;
  }

  .prose hr {
    border: none;
    border-top: 1px solid #bfc9bc;
    margin: 2rem 0;
  }

  .prose code {
    background-color: #f3ede7;
    padding: 0.125rem 0.25rem;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  .prose pre {
    background-color: #32302c;
    color: #f6f0ea;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    color: inherit;
  }

  .prose img {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
</style>
