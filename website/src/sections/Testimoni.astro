---

<section class="py-24 max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <div class="scroll-reveal">
      <h2 class="font-display-lg-mobile text-display-lg-mobile mb-6 font-fredoka">
        Bergabung dengan <span class="text-primary">15.000+ Keluarga</span> Bahagia
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant mb-8">
        Kepompong bukan sekadar aplikasi, tapi komunitas orang tua yang peduli
        akan kualitas tumbuh kembang karakter anak di era digital.
      </p>
      <div class="flex gap-4">
        <div class="flex -space-x-4">
          {
            avatars.map((src) => (
              <img
                class="w-12 h-12 rounded-full border-2 border-white object-cover"
                alt="Parent avatar"
                src={src}
              />
            ))
          }
          <div
            class="w-12 h-12 rounded-full bg-primary-container text-on-primary-container flex items-center justify-center font-bold text-sm border-2 border-white font-fredoka"
          >
            +15k
          </div>
        </div>
      </div>
    </div>
    <div class="bg-surface-container p-10 rounded-3xl relative scroll-reveal overflow-hidden">
      <span
        class="material-symbols-outlined text-primary-container text-6xl absolute -top-6 -left-6 opacity-40 z-10"
        style="font-variation-settings: 'FILL' 1;">format_quote</span
      >
      <div class="grid">
        {
          testimonials.map((t, i) => (
            <div
              class:list={[
                "testi-slide col-start-1 row-start-1 transition-all duration-500 ease-in-out flex flex-col",
                i === 0 ? "opacity-100 translate-y-0" : "opacity-0 translate-y-4 pointer-events-none",
              ]}
              data-index={i}
            >
              <p class="italic text-headline-md font-normal mb-8 relative z-10">
                &ldquo;{t.quote}&rdquo;
              </p>
              <div class="flex items-center gap-4 mt-auto">
                <img
                  class="w-10 h-10 rounded-full object-cover border-2 border-white"
                  alt={t.name}
                  src={avatars[t.avatar]}
                />
                <div class="font-bold font-fredoka">{t.name}</div>
                <div class="w-1 h-1 bg-outline rounded-full"></div>
                <div class="text-on-surface-variant">{t.detail}</div>
              </div>
            </div>
          ))
        }
      </div>
      <div class="flex justify-center gap-2 mt-10">
        {
          testimonials.map((_, i) => (
            <button
              class:list={[
                "testi-dot w-2.5 h-2.5 rounded-full transition-all duration-300",
                i === 0 ? "bg-primary w-8" : "bg-outline-variant",
              ]}
              data-index={i}
              aria-label={`Testimonial ${i + 1}`}
            />
          ))
        }
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const slides = document.querySelectorAll(".testi-slide");
    const dots = document.querySelectorAll(".testi-dot");
    if (!slides.length || !dots.length) return;

    let current = 0;
    const total = slides.length;

    function goTo(index) {
      slides.forEach((s, i) => {
        s.classList.toggle("opacity-100", i === index);
        s.classList.toggle("translate-y-0", i === index);
        s.classList.toggle("opacity-0", i !== index);
        s.classList.toggle("translate-y-4", i !== index);
        s.classList.toggle("pointer-events-none", i !== index);
      });
      dots.forEach((d, i) => {
        d.classList.toggle("bg-primary", i === index);
        d.classList.toggle("w-8", i === index);
        d.classList.toggle("bg-outline-variant", i !== index);
        d.classList.toggle("w-2.5", i !== index);
      });
      current = index;
    }

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        goTo(Number(dot.dataset.index));
        resetTimer();
      });
    });

    let timer = setInterval(() => {
      goTo((current + 1) % total);
    }, 5000);

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(() => {
        goTo((current + 1) % total);
      }, 5000);
    }
  })();
</script>
