---
---

<section class="min-h-screen flex items-center px-margin-mobile md:px-margin-desktop py-20">
  <div class="max-w-[1200px] mx-auto w-full">
    <div class="text-center mb-16">
      <h1 class="font-display-lg-mobile md:text-display-lg text-display-lg-mobile mb-4 font-fredoka text-on-surface">
        Hubungi <span class="text-primary">Kami</span>
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto font-fredoka">
        Punya pertanyaan atau ingin berkolaborasi? Kami siap membantu Bunda.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="bg-white p-8 rounded-3xl shadow-sm border border-outline-variant scroll-reveal">
        <h2 class="font-headline-md text-headline-md mb-6 font-fredoka text-on-surface">Kirim Pesan</h2>
        <form class="space-y-5" id="contact-form">
          <div>
            <label class="block text-label-sm font-fredoka text-on-surface-variant mb-2">Nama Lengkap</label>
            <input
              type="text"
              placeholder="Masukkan nama Anda"
              class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-fredoka text-body-md"
            />
          </div>
          <div>
            <label class="block text-label-sm font-fredoka text-on-surface-variant mb-2">Email</label>
            <input
              type="email"
              placeholder="email@contoh.com"
              class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-fredoka text-body-md"
            />
          </div>
          <div>
            <label class="block text-label-sm font-fredoka text-on-surface-variant mb-2">Subjek</label>
            <select class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-fredoka text-body-md text-on-surface">
              <option>Pilih subjek</option>
              <option>Pertanyaan Umum</option>
              <option>Kerja Sama Bisnis</option>
              <option>Join Affiliate</option>
              <option>Konsultasi</option>
              <option>Lainnya</option>
            </select>
          </div>
          <div>
            <label class="block text-label-sm font-fredoka text-on-surface-variant mb-2">Pesan</label>
            <textarea
              rows="5"
              placeholder="Tuliskan pesan Anda di sini..."
              class="w-full px-4 py-3 rounded-xl border border-outline-variant bg-surface focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all font-fredoka text-body-md resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-primary text-on-primary px-6 py-3 rounded-xl font-bold flex items-center justify-center gap-2 hover:opacity-90 active:scale-[0.98] transition-all shadow-md hover:shadow-lg font-fredoka"
          >
            Kirim Pesan
            <span class="material-symbols-outlined">send</span>
          </button>
        </form>
      </div>

      <div class="space-y-6">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-outline-variant scroll-reveal">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">mail</span>
            </div>
            <div>
              <h3 class="font-headline-md text-headline-md font-fredoka">Email</h3>
              <p class="text-body-md text-on-surface-variant font-fredoka">hello@kepompong.id</p>
            </div>
          </div>
        </div>

        <div class="bg-white p-8 rounded-3xl shadow-sm border border-outline-variant scroll-reveal">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
              <span class="material-symbols-outlined text-primary">schedule</span>
            </div>
            <div>
              <h3 class="font-headline-md text-headline-md font-fredoka">Jam Operasional</h3>
              <p class="text-body-md text-on-surface-variant font-fredoka">Senin - Jumat: 09.00 - 17.00 WIB</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
