---
// Static site - pricing loaded via client-side fetch from external backend
const promoCode = import.meta.env.PROMO_CODE || "MELANGKAH2026";
const promoDiscount = import.meta.env.PROMO_DISCOUNT || 20;
const appUrl = import.meta.env.APP_URL || "https://app.kepompong.id";
const registerUrl = `${appUrl}/?action=register&trial=3`;
---

<section class="bg-secondary-container/30 py-24">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="text-center mb-16">
      <h2 class="font-headline-lg text-headline-lg mb-4 font-fredoka">
        Investasi Untuk Masa Depan
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant font-fredoka">
        Pilih paket yang paling sesuai dengan kebutuhan stimulasi anak Bunda.
      </p>
    </div>

    <!-- Loading state -->
    <div id="pricing-loading" class="grid grid-cols-1 md:grid-cols-3 gap-8 items-end">
      <div class="bg-white p-8 rounded-2xl border border-outline-variant animate-pulse">
        <div class="h-6 bg-gray-200 rounded w-1/2 mb-4"></div>
        <div class="h-4 bg-gray-200 rounded w-3/4 mb-6"></div>
        <div class="h-10 bg-gray-200 rounded w-2/3 mb-8"></div>
        <div class="space-y-3">
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
        </div>
      </div>
      <div class="bg-white p-8 rounded-2xl border-2 border-primary shadow-xl md:scale-105 rounded-3xl bg-primary/5 animate-pulse">
        <div class="h-6 bg-gray-200 rounded w-1/2 mb-4"></div>
        <div class="h-4 bg-gray-200 rounded w-3/4 mb-6"></div>
        <div class="h-10 bg-gray-200 rounded w-2/3 mb-8"></div>
        <div class="space-y-3">
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
        </div>
      </div>
      <div class="bg-white p-8 rounded-2xl border border-outline-variant animate-pulse">
        <div class="h-6 bg-gray-200 rounded w-1/2 mb-4"></div>
        <div class="h-4 bg-gray-200 rounded w-3/4 mb-6"></div>
        <div class="h-10 bg-gray-200 rounded w-2/3 mb-8"></div>
        <div class="space-y-3">
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
          <div class="h-4 bg-gray-200 rounded"></div>
        </div>
      </div>
    </div>

    <!-- Pricing cards container -->
    <div id="pricing-container" class="grid grid-cols-1 md:grid-cols-3 gap-8 items-end hidden">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- Promo -->
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div
      class="mt-16 bg-white p-6 rounded-2xl border-2 border-dashed border-primary mx-auto flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <div>
        <p class="font-bold text-headline-md font-fredoka">Punya kode promo?</p>
        <p class="text-on-surface-variant">Gunakan kode untuk potongan ekstra sebanyak 20%</p>
      </div>
      <div class="flex items-center gap-2">
        <div
          class="bg-primary/10 px-6 py-3 rounded-xl text-primary font-bold tracking-widest text-lg font-fredoka"
          id="promo-code-display"
        >
          {promoCode}
        </div>
        <button id="copy-promo" class="bg-primary text-white p-3 rounded-xl hover:opacity-90 active:scale-95 transition-all" aria-label="Copy promo code">
          <span id="copy-icon" class="material-symbols-outlined">content_copy</span>
          <span id="check-icon" class="material-symbols-outlined hidden">check</span>
        </button>
      </div>
    </div>
  </div>
</section>

<!-- Set pricing API URL globally before loading script -->
<script is:inline define:vars={{ backendUrl: import.meta.env.PUBLIC_PRICING_API_URL, registerUrl: registerUrl, promoCode: promoCode }}>
  window.PRICING_API_URL = backendUrl || '';
  window.REGISTER_URL = registerUrl || '';
  window.PROMO_CODE = promoCode || '';
</script>

<!-- Load pricing.js from public folder -->
<script is:inline src="/pricing.js"></script>

<script is:inline define:vars={{ promoCode: import.meta.env.PROMO_CODE }}>
  (function () {
    var btn = document.getElementById("copy-promo");
    var copyIcon = document.getElementById("copy-icon");
    var checkIcon = document.getElementById("check-icon");
    if (!btn) return;
    btn.addEventListener("click", function () {
      navigator.clipboard.writeText(promoCode).then(function () {
        if (copyIcon) copyIcon.classList.add("hidden");
        if (checkIcon) checkIcon.classList.remove("hidden");
        setTimeout(function () {
          if (copyIcon) copyIcon.classList.remove("hidden");
          if (checkIcon) checkIcon.classList.add("hidden");
        }, 2000);
      });
    });
  })();
</script>
