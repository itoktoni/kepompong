---
const faqs = [
  {
    q: "Apa itu Kepompong?",
    a: "Kepompong adalah platform parenting digital yang membantu orang tua menemukan ide bermain offline kreatif dan memantau perkembangan karakter anak seperti jujur, disiplin, dan mandiri.",
  },
  {
    q: "Bagaimana cara kerja rekomendasi aktivitas?",
    a: "Cukup masukkan usia dan minat anak, dalam 3 detik sistem kami akan merekomendasikan aktivitas bermain offline yang sesuai dengan bahan yang tersedia di rumah.",
  },
  {
    q: "Apakah bisa digunakan tanpa internet?",
    a: "Ya! Setelah aktivitas diunduh, worksheet dan panduan bermain bisa diakses tanpa koneksi internet. Cocok untuk waktu bermain tanpa gangguan gadget.",
  },
  {
    q: "Bagaimana fitur tracking karakter bekerja?",
    a: "Setelah sesi bermain, Bunda bisa input hasil observasi. Sistem akan menampilkan grafik perkembangan soft skill anak dari waktu ke waktu secara visual dan terukur.",
  },
  {
    q: "Berapa biaya berlangganan?",
    a: "Kami menyediakan paket mulai dari Rp 49.000/bulan hingga Rp 249.000/tahun. Ada juga masa trial agar Bunda bisa mencoba sebelum berlangganan.",
  },
];
---

<section class="py-24 px-margin-mobile md:px-margin-desktop">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-headline-lg text-headline-lg mb-4 font-fredoka">
        Pertanyaan yang Sering Diajukan
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant font-fredoka">
        Belum menemukan jawaban? Hubungi kami melalui halaman Contact.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start">
      <div class="md:col-span-7 space-y-3">
        {
          faqs.map((faq, i) => (
            <div class="bg-white border border-outline-variant rounded-2xl overflow-hidden scroll-reveal">
              <button
                class="faq-toggle w-full flex items-center justify-between p-5 text-left hover:bg-surface-container-low/50 transition-colors"
                data-index={i}
              >
                <span class="font-headline-md text-headline-md font-fredoka pr-4">
                  {faq.q}
                </span>
                <span class="material-symbols-outlined text-primary transition-transform duration-300 flex-shrink-0">
                  expand_more
                </span>
              </button>
              <div class="faq-content hidden px-5 pb-5">
                <p class="font-body-md text-body-md text-on-surface-variant">
                  {faq.a}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <div class="md:col-span-5 relative scroll-reveal">
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 bg-tertiary-container/10 rounded-full blur-3xl"></div>
        <div class="rounded-3xl overflow-hidden shadow-2xl relative border-8 border-white">
          <img
            class="w-full h-[400px] md:h-[500px] object-cover"
            alt="Parent and child learning together"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuDe4KCuZnhuIPJup87HeB8_AdMOincQ-ZdAJw6RraeaEFbT82h3O4VX9ydZxsvC-u_jcm9rzk02dWH1GymMJhJFIf34LqlL10DdT4IXWxIAzNU4kz63TgWKySyH_lDDkbt_mga1HD-Acwx5vbljoVCSGwHXakHDcMk2e5QLXkR8xs0LKL1jnYTz8CbLUl6tnMdCIoAvtvKn_kyNWRMGgBXls6LVcDoHlQOiYJthnBhKMP7X_w4TWWfUBZW2cVqFNroVTk80y-tftih8"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll(".faq-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const content = btn.nextElementSibling;
      const icon = btn.querySelector(".material-symbols-outlined");
      const isOpen = !content.classList.contains("hidden");

      document.querySelectorAll(".faq-content").forEach((c) => c.classList.add("hidden"));
      document.querySelectorAll(".faq-toggle .material-symbols-outlined").forEach((i) => {
        i.style.transform = "rotate(0deg)";
      });

      if (!isOpen) {
        content.classList.remove("hidden");
        icon.style.transform = "rotate(180deg)";
      }
    });
  });
</script>
