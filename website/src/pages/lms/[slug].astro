---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("lms", ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get related posts
const allPosts = await getCollection("lms", ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);
---

<Layout title={`${post.data.title} | LMS Kepompong`} description={post.data.description}>
  <main class="min-h-screen bg-surface">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-secondary font-fredoka border-b border-outline">
      <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-6 w-full flex items-center gap-2">
        <a href="/lms" class="hover:text-primary transition-colors">Modul</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
        <span class="text-on-surface truncate max-w-[200px] md:max-w-none">{post.data.title}</span>
      </div>
    </nav>

    <!-- Hero Image - Full Width -->
    {post.data.image && (
      <div class="w-full bg-surface-container-low">
        <div class="max-h-[60vh] overflow-hidden">
          <img
            src={post.data.image.url}
            alt={post.data.image.alt}
            class="w-full h-full object-cover"
          />
        </div>
      </div>
    )}

    <!-- Content -->
    <article class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop py-8 md:py-12">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <!-- Meta -->
          <div class="flex flex-wrap items-center gap-3 mb-6">
            <span class="bg-primary/10 text-primary px-4 py-2 rounded-full font-fredoka text-body-sm">
              {post.data.category}
            </span>
            <span class="bg-surface-container-low text-secondary px-4 py-2 rounded-full font-fredoka text-body-sm">
              {post.data.level}
            </span>
            {post.data.duration && (
              <span class="flex items-center gap-2 text-secondary font-fredoka text-body-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {post.data.duration}
              </span>
            )}
          </div>

          <!-- Title -->
          <h1 class="font-fredoka text-headline-xl md:text-display-md text-on-surface mb-6">
            {post.data.title}
          </h1>

          <!-- Description -->
          <p class="font-fredoka text-body-lg text-secondary mb-8">
            {post.data.description}
          </p>

          <!-- Content Body -->
          <div class="prose prose-lg lms-content overflow-hidden">
            <Content />
          </div>

          <!-- CTA -->
          <div class="mt-12 bg-primary/10 rounded-2xl p-8 text-center">
            <h3 class="font-fredoka text-headline-md text-on-surface mb-4">
              Ingin belajar lebih banyak?
            </h3>
            <p class="font-fredoka text-body-md text-secondary mb-6">
              Download aplikasi Kepompong untuk akses ratusan aktivitas dan tracking karakter anak
            </p>
            <a href="/register" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-full font-fredoka text-body-lg hover:bg-primary/90 transition-colors">
              Mulai Sekarang
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="lg:w-80 shrink-0 space-y-6">
          <!-- Activity Types -->
          <div class="lg:sticky lg:top-8 bg-surface-container-low rounded-2xl p-6 border border-outline">
            <h2 class="font-fredoka text-headline-md text-on-surface mb-4">Tipe Aktivitas</h2>
            <div class="space-y-1.5">
              {[
                { emoji: '📖', label: 'Storytelling', key: 'storytelling' },
                { emoji: '🎭', label: 'Bermain Peran', key: 'bermain_peran' },
                { emoji: '🎲', label: 'Permainan', key: 'permainan' },
                { emoji: '🎤', label: 'Monolog', key: 'monolog' },
                { emoji: '🎨', label: 'Proyek Kreatif', key: 'proyek_kreatif' },
                { emoji: '🎵', label: 'Musik & Gerak', key: 'musik_gerak' },
                { emoji: '🧩', label: 'Puzzle', key: 'puzzle' },
                { emoji: '🧘', label: 'Mindfulness', key: 'mindfulness' },
                { emoji: '🌿', label: 'Outdoor', key: 'outdoor' },
                { emoji: '🔬', label: 'Ilmu Pengetahuan', key: 'ilmu_pengetahuan' },
                { emoji: '🤔', label: 'Tebak-tebakan', key: 'tebak_tebakan' },
                { emoji: '🤲', label: 'Permainan Tangan', key: 'permainan_tangan' },
                { emoji: '🧠', label: 'Latihan Otak', key: 'latihan_otak' },
                { emoji: '💬', label: 'Komik', key: 'komik' },
                { emoji: '🖍️', label: 'Coloring', key: 'coloring' },
                { emoji: '🪣', label: 'Mengenal Kata', key: 'mengenal_kata' },
              ].map((t) => (
                <a
                  href={`/panduan-upload#${t.key}`}
                  class="group flex items-center gap-3 bg-surface rounded-xl hover:shadow-md transition-all border border-transparent hover:border-primary/20 px-3 py-2.5"
                >
                  <span class="text-lg shrink-0">{t.emoji}</span>
                  <span class="font-fredoka text-sm text-on-surface group-hover:text-primary transition-colors flex-1">{t.label}</span>
                  <svg class="w-3.5 h-3.5 text-secondary group-hover:text-primary group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              ))}
            </div>
            <a href="/panduan-upload" class="mt-4 w-full flex items-center justify-center gap-2 bg-primary/10 text-primary px-4 py-3 rounded-xl font-fredoka text-body-sm hover:bg-primary/20 transition-colors">
              Lihat Panduan Upload
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>

          <!-- Related Posts -->
          {relatedPosts.length > 0 && (
            <div class="lg:sticky lg:top-[calc(100vh-2rem)] bg-surface-container-low rounded-2xl p-6 border border-outline">
              <h2 class="font-fredoka text-headline-md text-on-surface mb-4">Modul Terkait</h2>
              <div class="space-y-3">
                {relatedPosts.map(relPost => (
                  <a
                    href={`/lms/${relPost.id}`}
                    class="group flex items-center gap-3 bg-surface rounded-xl hover:shadow-md transition-all border border-transparent hover:border-primary/20 p-3"
                  >
                    <div class="flex-1 min-w-0">
                      <h3 class="font-fredoka text-sm text-on-surface group-hover:text-primary transition-colors line-clamp-2">
                        {relPost.data.title}
                      </h3>
                    </div>
                    <svg class="w-4 h-4 text-secondary group-hover:text-primary group-hover:translate-x-1 transition-all shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                ))}
              </div>
              <a href="/lms" class="mt-4 w-full flex items-center justify-center gap-2 bg-primary/10 text-primary px-4 py-3 rounded-xl font-fredoka text-body-sm hover:bg-primary/20 transition-colors">
                Lihat Semua Modul
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          )}
        </aside>
      </div>
    </article>
  </main>
</Layout>

<style>
  .lms-content {
    overflow-x: hidden;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }
  .lms-content :global(h2) {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: #1d1b18;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 3px solid #B7D9BC;
  }
  .lms-content :global(h3) {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.35rem;
    font-weight: 600;
    color: #176c33;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    padding-top: 1.5rem;
    border-top: 2px solid #e5e7eb;
  }
  .lms-content :global(h3:first-child) {
    border-top: none;
    padding-top: 0;
  }
  .lms-content :global(p) {
    font-family: 'Fredoka', sans-serif;
    font-size: 1rem;
    line-height: 1.75;
    color: #40493f;
    margin-bottom: 0.75rem;
  }
  .lms-content :global(ul),
  .lms-content :global(ol) {
    font-family: 'Fredoka', sans-serif;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .lms-content :global(li) {
    font-size: 1rem;
    line-height: 1.75;
    color: #40493f;
    margin-bottom: 0.25rem;
  }
  .lms-content :global(strong) {
    color: #176c33;
    font-weight: 600;
  }
  .lms-content :global(code) {
    background: #f3ede7;
    padding: 0.15rem 0.4rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: #176c33;
  }
  .lms-content :global(pre) {
    background: #1a1a2e;
    border-radius: 1rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    border: 2px solid #B7D9BC;
    max-width: 100%;
  }
  .lms-content :global(pre.astro-code) {
    max-width: 100%;
    overflow-x: auto;
  }
  .lms-content :global(pre code) {
    background: transparent;
    padding: 0;
    color: #4ade80;
    font-size: 0.85rem;
    line-height: 1.6;
  }
  .lms-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-family: 'Fredoka', sans-serif;
    border-radius: 1rem;
    overflow: hidden;
    border: 2px solid #B7D9BC;
  }
  .lms-content :global(th) {
    background: #E8F5E9;
    color: #176c33;
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    text-align: left;
    border-bottom: 2px solid #B7D9BC;
  }
  .lms-content :global(td) {
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #40493f;
    border-bottom: 1px solid #e5e7eb;
  }
  .lms-content :global(tr:last-child td) {
    border-bottom: none;
  }
  .lms-content :global(a) {
    color: #176c33;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .lms-content :global(a:hover) {
    color: #0d4a22;
  }
  .lms-content :global(hr) {
    border: none;
    border-top: 2px solid #B7D9BC;
    margin: 2.5rem 0;
  }
  .lms-content :global(details) {
    background: #f8f3ed;
    border: 2px solid #B7D9BC;
    border-radius: 1rem;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
  }
  .lms-content :global(summary) {
    cursor: pointer;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    color: #176c33;
    font-size: 0.95rem;
  }
  .lms-content :global(details[open]) {
    padding-bottom: 1.25rem;
  }
</style>
