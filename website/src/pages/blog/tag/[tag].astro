---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const slugify = (str: string) => str.toLowerCase().replace(/\s+/g, '-');
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const allTags = [...new Set(allPosts.flatMap(post => post.data.tags))];
  const categories = [...new Set(allPosts.map(post => post.data.category))];

  return allTags.map((tag) => {
    const filteredPosts = allPosts
      .filter(post => post.data.tags.includes(tag))
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { tag: slugify(tag) },
      props: { tag, posts: filteredPosts, allCategories: categories },
    };
  });
}

interface Props {
  tag: string;
  posts: any[];
  allCategories: string[];
}

const { tag, posts, allCategories } = Astro.props;
---

<Layout pageKey="/">
  <main class="max-w-6xl mx-auto px-margin-mobile md:px-margin-desktop py-20">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm">
      <ol class="flex items-center gap-2 text-on-surface-variant">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
        <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
        <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
        <li class="text-on-surface">Tag: #{tag}</li>
      </ol>
    </nav>

    <!-- Header -->
    <section class="text-center mb-12">
      <span class="inline-block px-4 py-2 bg-tertiary-container text-on-tertiary-container rounded-full text-label-lg mb-4">
        Tag
      </span>
      <h1 class="font-fredoka text-4xl md:text-5xl font-bold text-leaf-deep mb-4">
        #{tag}
      </h1>
      <p class="text-lg text-on-surface-variant">
        {posts.length} artikel dengan tag ini
      </p>
    </section>

    <!-- Categories Filter -->
    <section class="mb-8">
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="/blog" class="px-4 py-2 bg-surface-variant text-on-surface-variant rounded-full font-fredoka text-label-lg hover:bg-primary hover:text-on-primary transition-colors">
          Semua
        </a>
        {allCategories.map((cat) => (
          <a
            href={`/blog/category/${cat.toLowerCase()}`}
            class="px-4 py-2 bg-surface-variant text-on-surface-variant rounded-full font-fredoka text-label-lg hover:bg-primary hover:text-on-primary transition-colors"
          >
            {cat}
          </a>
        ))}
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {posts.map((post) => (
        <article class="bg-surface-container rounded-2xl overflow-hidden bento-card shadow-md">
          {post.data.image && (
            <a href={`/blog/${post.id}`} class="block">
              <img
                src={post.data.image.url}
                alt={post.data.image.alt}
                class="w-full h-48 object-cover"
              />
            </a>
          )}
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <a
                href={`/blog/category/${post.data.category.toLowerCase()}`}
                class="px-3 py-1 bg-primary-container text-on-primary-container text-label-sm rounded-full"
              >
                {post.data.category}
              </a>
              <span class="text-xs text-on-surface-variant">
                {post.data.pubDate.toLocaleDateString('id-ID', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </span>
            </div>
            <h2 class="font-fredoka text-xl font-bold text-on-surface mb-2 line-clamp-2">
              <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-1">
              {post.data.tags.map((postTag) => (
                <span
                  class:list={[
                    "px-2 py-0.5 text-label-sm rounded-full",
                    postTag === tag
                      ? "bg-primary text-on-primary"
                      : "bg-surface-variant text-on-surface-variant hover:bg-primary hover:text-on-primary transition-colors"
                  ]}
                >
                  #{postTag}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Back to Blog -->
    <div class="mt-8 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full hover:opacity-90 transition-opacity font-fredoka"
      >
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Kembali ke Semua Artikel
      </a>
    </div>
  </main>
</Layout>
