---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(post => post.data.category))];

  return categories.map((cat) => {
    const filteredPosts = allPosts
      .filter(post => post.data.category === cat)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: { category: cat.toLowerCase() },
      props: { category: cat, posts: filteredPosts, allCategories: categories },
    };
  });
}

interface Props {
  category: string;
  posts: any[];
  allCategories: string[];
}

const { category, posts, allCategories } = Astro.props;

// Get all unique tags from filtered posts
const allTags = posts.flatMap(post => post.data.tags);
const uniqueTags = [...new Set(allTags)];
---

<Layout pageKey="/">
  <main class="max-w-6xl mx-auto px-margin-mobile md:px-margin-desktop py-20">
    <!-- Breadcrumb -->
    <nav class="mb-8 text-sm">
      <ol class="flex items-center gap-2 text-on-surface-variant">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
        <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
        <li><span class="material-symbols-outlined text-xs">chevron_right</span></li>
        <li class="text-on-surface">{category}</li>
      </ol>
    </nav>

    <!-- Header -->
    <section class="text-center mb-12">
      <span class="inline-block px-4 py-2 bg-primary-container text-on-primary-container rounded-full text-label-lg mb-4">
        Kategori
      </span>
      <h1 class="font-fredoka text-4xl md:text-5xl font-bold text-leaf-deep mb-4">
        {category}
      </h1>
      <p class="text-lg text-on-surface-variant">
        {posts.length} artikel dalam kategori ini
      </p>
    </section>

    <!-- Categories Filter -->
    <section class="mb-8">
      <div class="flex flex-wrap gap-2 justify-center">
        <a href="/blog" class="px-4 py-2 bg-surface-variant text-on-surface-variant rounded-full font-fredoka text-label-lg hover:bg-primary hover:text-on-primary transition-colors">
          Semua
        </a>
        {allCategories.map(cat => (
          <a
            href={`/blog/category/${cat.toLowerCase()}`}
            class:list={[
              "px-4 py-2 rounded-full font-fredoka text-label-lg transition-colors",
              cat === category
                ? "bg-primary text-on-primary cursor-default"
                : "bg-surface-variant text-on-surface-variant hover:bg-primary hover:text-on-primary"
            ]}
          >
            {cat}
          </a>
        ))}
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      {posts.map((post) => (
        <article class="bg-surface-container rounded-2xl overflow-hidden bento-card shadow-md">
          {post.data.image && (
            <a href={`/blog/${post.id}`} class="block">
              <img
                src={post.data.image.url}
                alt={post.data.image.alt}
                class="w-full h-48 object-cover"
              />
            </a>
          )}
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs text-on-surface-variant">
                {post.data.pubDate.toLocaleDateString('id-ID', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric'
                })}
              </span>
            </div>
            <h2 class="font-fredoka text-xl font-bold text-on-surface mb-2 line-clamp-2">
              <a href={`/blog/${post.id}`} class="hover:text-primary transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-sm text-on-surface-variant mb-4 line-clamp-3">
              {post.data.description}
            </p>
            <div class="flex flex-wrap gap-1">
              {post.data.tags.slice(0, 3).map((tag) => (
                <a
                  href={`/blog/tag/${tag}`}
                  class="px-2 py-0.5 bg-surface-variant text-on-surface-variant text-label-sm rounded-full hover:bg-primary hover:text-on-primary transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </section>

    <!-- Tags in this category -->
    {uniqueTags.length > 0 && (
      <section class="bg-surface-container rounded-2xl p-6">
        <h3 class="font-fredoka text-xl font-bold text-on-surface mb-4">
          Tags dalam {category}
        </h3>
        <div class="flex flex-wrap gap-2">
          {uniqueTags.map((tag) => (
            <a
              href={`/blog/tag/${tag}`}
              class="px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-label-lg hover:bg-primary hover:text-on-primary transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Back to Blog -->
    <div class="mt-8 text-center">
      <a
        href="/blog"
        class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-on-primary rounded-full hover:opacity-90 transition-opacity font-fredoka"
      >
        <span class="material-symbols-outlined text-base">arrow_back</span>
        Kembali ke Semua Artikel
      </a>
    </div>
  </main>
</Layout>
