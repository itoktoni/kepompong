---

<footer class="bg-surface-container dark:bg-surface-container-highest mt-20">
  <div
    class="flex flex-col md:flex-row justify-between items-center px-margin-mobile md:px-margin-desktop py-xl gap-lg max-w-[1200px] mx-auto"
  >
    <div class="flex flex-col gap-sm text-center md:text-left">
      <div
        class="text-headline-md font-headline-md text-leaf-deep dark:text-primary-fixed-dim font-fredoka"
      >
        {brand}
      </div>
      <p
        class="text-secondary dark:text-secondary-fixed-dim font-body-md max-w-sm"
      >
        {tagline}
      </p>
    </div>
    <div class="flex flex-wrap justify-center gap-lg font-fredoka">
      {
        links.map((link) => (
          <a
            class="text-secondary dark:text-secondary-fixed-dim hover:text-primary dark:hover:text-primary-fixed transition-all font-label-sm text-label-lg"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="flex gap-md">
      {
        socials.map((social) => (
          <a
            class="w-10 h-10 rounded-full bg-white flex items-center justify-center text-primary shadow-sm hover:scale-110 transition-transform"
            href={social.href}
            aria-label={social.label}
            set:html={svgIcons[social.icon] || ""}
          />
        ))
      }
    </div>
  </div>
</footer>
