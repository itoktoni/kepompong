---
const plans = [
  {
    name: "Paket Coba-Coba",
    duration: "Akses penuh 1 Bulan",
    price: "Rp 49.000",
    features: [
      "Unlimited Ide Bermain",
      "Tracking 3 Karakter",
      "Akses Worksheet Dasar",
    ],
    variant: "outline",
  },
  {
    name: "Paket Juara",
    duration: "Akses penuh 12 Bulan",
    price: "Rp 249.000",
    originalPrice: "Rp 588.000",
    badge: "REKOMENDASI BUNDA",
    features: [
      "Semua fitur Paket Fokus",
      "Webinar Eksklusif Parenting",
      "Sertifikat Metamorfosis Anak",
      "Konsultasi via Chat Premium",
    ],
    variant: "primary",
  },
  {
    name: "Paket Fokus",
    duration: "Akses penuh 3 Bulan",
    price: "Rp 129.000",
    features: [
      "Semua fitur Paket Coba",
      "Laporan Mingguan PDF",
      "Full Library Worksheet",
    ],
    variant: "outline",
  },
];
---

<section class="bg-secondary-container/30 py-24">
  <div class="max-w-[1200px] mx-auto px-margin-mobile md:px-margin-desktop">
    <div class="text-center mb-16">
      <h2 class="font-headline-lg text-headline-lg mb-4 font-fredoka">
        Investasi Untuk Masa Depan
      </h2>
      <p class="font-body-lg text-body-lg text-on-surface-variant font-fredoka">
        Pilih paket yang paling sesuai dengan kebutuhan stimulasi anak Bunda.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-end">
      {
        plans.map((plan) => (
          <div
            class:list={[
              "bg-white p-8 rounded-2xl shadow-sm hover:shadow-md transition-shadow relative scroll-reveal",
              plan.variant === "primary"
                ? "border-2 border-primary shadow-xl md:scale-105 rounded-3xl bg-primary/5"
                : "border border-outline-variant",
            ]}
          >
            {plan.badge && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-on-primary px-4 py-1 rounded-full text-label-sm font-normal">
                {plan.badge}
              </div>
            )}
            <h3 class="font-headline-md text-headline-md mb-2 font-fredoka">
              {plan.name}
            </h3>
            <p class="text-on-surface-variant text-label-lg mb-6">
              {plan.duration}
            </p>
            <div class="mb-8">
              <span
                class:list={[
                  "text-display-lg-mobile font-bold font-fredoka",
                  plan.variant === "primary" ? "text-primary" : "",
                ]}
              >
                {plan.price}
              </span>
              {plan.originalPrice && (
                <span class="block text-label-sm text-on-surface-variant line-through opacity-60">
                  {plan.originalPrice}
                </span>
              )}
            </div>
            <ul class="space-y-4 mb-10">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-primary text-sm">
                    check_circle
                  </span>
                  {feature}
                </li>
              ))}
            </ul>
            <a
              href="/#cta"
              class:list={[
                "w-full py-3 rounded-xl text-lg transition-colors font-fredoka text-center block",
                plan.variant === "primary"
                  ? "bg-primary text-on-primary shadow-lg hover:opacity-90 py-4"
                  : "border border-primary text-primary hover:bg-primary/5",
              ]}
            >
              {plan.variant === "primary" ? "Langganan Sekarang" : "Pilih Paket"}
            </a>
          </div>
        ))
      }
    </div>
    <!-- Promo -->
    <div
      class="mt-16 bg-white p-6 rounded-2xl border-2 border-dashed border-primary mx-auto flex flex-col md:flex-row items-center justify-between gap-6"
    >
      <div>
        <p class="font-bold text-headline-md font-fredoka">Punya kode promo?</p>
        <p class="text-on-surface-variant">Gunakan kode untuk potongan ekstra sebanyak 20%</p>
      </div>
      <div class="flex items-center gap-2">
        <div
          class="bg-primary/10 px-6 py-3 rounded-xl text-primary font-bold tracking-widest text-lg font-fredoka"
        >
          MELANGKAH2026
        </div>
        <button id="copy-promo" class="bg-primary text-white p-3 rounded-xl hover:opacity-90 active:scale-95 transition-all" aria-label="Copy promo code">
          <span id="copy-icon" class="material-symbols-outlined">content_copy</span>
          <span id="check-icon" class="material-symbols-outlined hidden">check</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const btn = document.getElementById("copy-promo");
    const copyIcon = document.getElementById("copy-icon");
    const checkIcon = document.getElementById("check-icon");
    if (!btn) return;

    btn.addEventListener("click", () => {
      navigator.clipboard.writeText("EARLYBUNDA").then(() => {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      });
    });
  })();
</script>
