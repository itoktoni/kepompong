---
const steps = [
  {
    num: 1,
    title: "Onboarding",
    desc: "Daftarkan profil dan minat unik si kecil.",
  },
  {
    num: 2,
    title: "Recommendation",
    desc: "Dapatkan ide bermain personal dalam 3 detik.",
  },
  {
    num: 3,
    title: "Offline Play",
    desc: "Waktunya bermain nyata tanpa gangguan gadget.",
  },
  {
    num: 4,
    title: "Assessment",
    desc: "Input hasil bermain & lihat grafik karakter.",
  },
];
---

<section class="py-24 px-margin-mobile md:px-margin-desktop max-w-[1200px] mx-auto">
  <div class="text-center mb-16">
    <h2 class="font-headline-lg text-headline-lg mb-4 font-fredoka">
      Perjalanan Metamorfosis Si Kecil
    </h2>
    <p
      class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto font-fredoka"
    >
      Dari ulat yang lapar akan ilmu menjadi kupu-kupu karakter yang indah.
    </p>
  </div>
  <div class="relative">
    <div
      class="hidden md:block absolute top-1/2 left-0 w-full h-0.5 -translate-y-1/2 z-0"
      style="background-image: linear-gradient(to right, #bfc9bc 50%, rgba(255,255,255,0) 0%); background-position: bottom; background-size: 15px 1px; background-repeat: repeat-x;"
    >
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative">
      {
        steps.map((step, i) => (
          <div class="relative bg-surface p-6 rounded-2xl text-center z-10 border border-outline-variant md:border-transparent scroll-reveal">
            <div class="w-16 h-16 bg-primary text-on-primary rounded-full flex items-center justify-center mx-auto mb-6 text-xl font-bold shadow-lg font-fredoka">
              {step.num}
            </div>
            <h4 class="font-headline-md text-headline-md mb-2 font-fredoka">
              {step.title}
            </h4>
            <p class="font-body-md text-body-md text-on-surface-variant">
              {step.desc}
            </p>
            {i < steps.length - 1 && (
              <div class="hidden md:flex absolute top-1/2 -right-5 -translate-y-1/2 z-20 w-10 h-10 bg-white rounded-full items-center justify-center shadow-sm border border-outline-variant">
                <span class="material-symbols-outlined text-primary text-xl">arrow_forward</span>
              </div>
            )}
            {i < steps.length - 1 && (
              <div class="md:hidden flex justify-center py-2">
                <span class="material-symbols-outlined text-primary text-2xl rotate-90">arrow_forward</span>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
